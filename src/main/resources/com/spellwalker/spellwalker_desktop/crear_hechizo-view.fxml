<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="900.0" prefWidth="1764.0" styleClass="root-pane" stylesheets="@crear_hechizo.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.spellwalker.CrearHechizoController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="25" styleClass="main-container" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="55.0">
            <Text fill="white" styleClass="title-text" text="CREACIÓN DE HECHIZO">
                <font><Font size="48.0" /></font>
            </Text>

            <GridPane alignment="CENTER" hgap="40" vgap="20">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="200" />
                    <ColumnConstraints halignment="LEFT" minWidth="350" />
                </columnConstraints>

                <Text styleClass="label-text" text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="campoNombre" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Text styleClass="label-text" text="Coste AP:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="campoAp" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Text styleClass="label-text" text="Coste Maná:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="campoMana" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Text styleClass="label-text" text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="comboTipo" prefWidth="350" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Text styleClass="label-text" text="Velocidad:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <ComboBox fx:id="comboVelocidad" prefWidth="350" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Text styleClass="label-text" text="Escuela:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="comboEscuela" prefWidth="350" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <HBox spacing="40" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="6">
                    <CheckBox fx:id="checkLegendario" text="Legendario" styleClass="label-text" />
                    <CheckBox fx:id="checkFusion" text="Fusión" styleClass="label-text" />
                </HBox>
            </GridPane>

            <HBox alignment="CENTER" spacing="40">
                <Button onAction="#handlerCrear" prefHeight="80.0" prefWidth="300.0" styleClass="primary-button" text="Crear Hechizo" />
                <Button onAction="#handlerVolver" prefHeight="80.0" prefWidth="300.0" styleClass="secondary-button" text="Volver" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>

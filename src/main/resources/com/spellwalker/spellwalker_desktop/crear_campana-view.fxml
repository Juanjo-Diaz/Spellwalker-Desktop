<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>

<StackPane styleClass="root-pane" stylesheets="@crear_campana.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.spellwalker.spellwalker_desktop.CrearCampanaController">

    <children>
        <VBox alignment="CENTER" spacing="30" styleClass="main-container" maxWidth="750" maxHeight="550">
            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <Text styleClass="title-text" text="CREACIÓN DE CAMPAÑA">
                <font><Font size="48.0"/></font>
            </Text>

            <VBox alignment="CENTER_LEFT" spacing="10" maxWidth="600">
                <Text styleClass="label-text" text="Nombre de la campaña">
                    <font><Font size="24.0"/></font>
                </Text>
                <TextField fx:id="campoNombre" prefHeight="50" styleClass="input-field"/>

                <Text styleClass="label-text" text="Descripción">
                    <font><Font size="24.0"/></font>
                </Text>
                <TextArea fx:id="campoDescripcion" prefHeight="150" wrapText="true" styleClass="text-area"/>
            </VBox>

            <HBox alignment="CENTER" spacing="40">
                <Button onAction="#handlerCrear" prefHeight="60.0" prefWidth="250.0" styleClass="primary-button" text="Crear Campaña"/>
                <Button onAction="#handlerVolver" prefHeight="60.0" prefWidth="250.0" styleClass="secondary-button" text="Volver"/>
            </HBox>

        </VBox>
    </children>
</StackPane>

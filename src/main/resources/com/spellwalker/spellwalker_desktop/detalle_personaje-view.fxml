<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="900.0" prefWidth="1764.0" styleClass="root" stylesheets="@detalle_personaje.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spellwalker.spellwalker_desktop.DetallePersonajeController">
    <children>
        <VBox alignment="CENTER" spacing="20" styleClass="main-container" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="50.0" AnchorPane.bottomAnchor="50.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

    <Label fx:id="lblTitulo" styleClass="title-text"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="150"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Campaña:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="label-text"/>
        <Label fx:id="lblCampana" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="label-text"/>

        <Label text="Escuelas (máx 3):" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="label-text"/>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbEscuelas" prefWidth="200" styleClass="input-field"/>
                <Button text="Añadir Escuela" onAction="#handlerAnadirEscuela" styleClass="primary-button"/>
            </HBox>
            <ListView fx:id="lvEscuelas" fixedCellSize="32.0" prefHeight="98.0" minHeight="98.0" maxHeight="98.0"/>
            <Button text="Eliminar Escuela Seleccionada" onAction="#handlerEliminarEscuela" styleClass="secondary-button"/>
        </VBox>

        <Label text="Hechizos:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="label-text"/>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbHechizos" prefWidth="200" styleClass="input-field"/>
                <Button text="Añadir Hechizo" onAction="#handlerAnadirHechizo" styleClass="primary-button"/>
                <Button onAction="#handlerIrACrearHechizo" styleClass="primary-button" text="Crear nuevo hechizo"/>
            </HBox>
            <TableView fx:id="tvHechizos" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colCosteAp" text="AP" prefWidth="50"/>
                    <TableColumn fx:id="colCosteMana" text="Maná" prefWidth="50"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colVelocidad" text="Velocidad" prefWidth="100"/>
                    <TableColumn fx:id="colLegendario" text="Legendario" prefWidth="80"/>
                    <TableColumn fx:id="colFusion" text="Fusión" prefWidth="80"/>
                </columns>
            </TableView>
            <Button text="Eliminar Hechizo Seleccionado" onAction="#handlerEliminarHechizo" styleClass="secondary-button"/>
        </VBox>

        <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="label-text"/>
        <TextArea fx:id="taDescripcion" prefHeight="100" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="input-field"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Borrar Personaje" onAction="#handlerBorrarPersonaje" styleClass="secondary-button"/>
        <Button text="Guardar Cambios" onAction="#handlerGuardar" styleClass="primary-button"/>
        <Button text="Volver" onAction="#handlerVolver" styleClass="primary-button"/>
    </HBox>

        </VBox>
    </children>
</AnchorPane>

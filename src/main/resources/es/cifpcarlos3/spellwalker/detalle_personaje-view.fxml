<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.spellwalker.DetallePersonajeController" styleClass="main-container">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="lblTitulo" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="150"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Campaña:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblCampana" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Escuelas (máx 3):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbEscuelas" prefWidth="200"/>
                <Button text="Añadir Escuela" onAction="#handlerAnadirEscuela"/>
            </HBox>
            <ListView fx:id="lvEscuelas" prefHeight="100"/>
            <Button text="Eliminar Escuela Seleccionada" onAction="#handlerEliminarEscuela"/>
        </VBox>

        <Label text="Hechizos:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbHechizos" prefWidth="200"/>
                <Button text="Añadir Hechizo" onAction="#handlerAnadirHechizo"/>
            </HBox>
            <TableView fx:id="tvHechizos" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colCosteAp" text="AP" prefWidth="50"/>
                    <TableColumn fx:id="colCosteMana" text="Maná" prefWidth="50"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colVelocidad" text="Velocidad" prefWidth="100"/>
                    <TableColumn fx:id="colLegendario" text="Legendario" prefWidth="80"/>
                    <TableColumn fx:id="colFusion" text="Fusión" prefWidth="80"/>
                </columns>
            </TableView>
            <Button text="Eliminar Hechizo Seleccionado" onAction="#handlerEliminarHechizo"/>
        </VBox>

        <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextArea fx:id="taDescripcion" prefHeight="100" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Borrar Personaje" onAction="#handlerBorrarPersonaje" style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
        <Button text="Guardar Cambios" onAction="#handlerGuardar"/>
        <Button text="Volver" onAction="#handlerVolver"/>
    </HBox>

</VBox>
